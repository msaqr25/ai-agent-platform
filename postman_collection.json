        {
          "name": "Send Voice Message",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const sessionId = pm.collectionVariables.get('session_id');",
                  "if (!sessionId) {",
                  "  throw new Error('Missing collection variable: session_id');",
                  "}",
                  "",
                  "const audioSrc = pm.request.body.formdata?.find(",
                  "  f => f.key === 'audio' && f.type === 'file'",
                  ");",
                  "if (!audioSrc || !audioSrc.src) {",
                  "  console.warn(",
                  "    'No audio file selected. Click the audio field, select a .wav/.mp3/.ogg/.webm file.'",
                  "  );",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 400) {",
                  "  const json = pm.response.json();",
                  "  pm.test('Returns a 400 error with code', function () {",
                  "    pm.expect(json).to.have.property('code');",
                  "    pm.expect(json.detail).to.be.a('string');",
                  "  });",
                  "  pm.test('Skipping — no audio file selected or invalid file', function () {});",
                  "  return;",
                  "}",
                  "",
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response has all voice fields', function () {",
                  "  pm.expect(json).to.have.property('user_message');",
                  "  pm.expect(json).to.have.property('assistant_message');",
                  "  pm.expect(json).to.have.property('audio_file');",
                  "});",
                  "",
                  "pm.test('audio_file has expected structure', function () {",
                  "  pm.expect(json.audio_file).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
