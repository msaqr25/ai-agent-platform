# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ─── OpenAI (needed for voice/chat features) ───────────────────────────────────
# OPENAI_API_KEY=sk-...
OPENAI_MODEL_NAME=gpt-4o-mini
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_OUTPUT_MIME=audio/mpeg

# ─── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed origins (comma-separated within brackets).
# CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173"]'

# ─── Audio / File Storage ──────────────────────────────────────────────────────
AUDIO_STORAGE_DIR=data/audio_files
# Max upload size in bytes (default: 10 MB)
# MAX_AUDIO_FILE_SIZE=10485760
